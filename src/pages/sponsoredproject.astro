---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import Newletter from "../components/Newletter.astro";
import aboutcover from "../assets/About_images/banner5.png";
---

<Layout title="About Us">
  <!-- Banner (same as About page) -->
  <section class="relative overflow-hidden">
    <div class="relative w-full h-[60vh] sm:h-[50vh] md:h-[60vh] lg:h-[88vh] overflow-hidden">
      <img
        src={aboutcover.src}
        alt="Sponsored Projects at School of Sustainability, IIT Madras"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        decoding="async"
        width="1920"
        height="1080"
      />
      <div class="absolute inset-0 bg-black/30"></div>
    </div>
  </section>

  <!-- Main Section -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div id="patent-tables">
      <!-- Loader skeleton -->
      <section class="mb-16">
        <h2 class="text-2xl font-semibold text-green-700 mb-4 text-center">
          Loading Sponsored Projects...
        </h2>
      </section>
    </div>
  </main>

  <!-- Scroll to top button -->
  <button
  id="scrollToTop"
  class="fixed bottom-6 right-6 z-50 bg-white border-2 border-green-600 text-green-600 p-3 rounded-full shadow-md transition-all duration-300 opacity-0 pointer-events-none"
  aria-label="Scroll to top"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="w-5 h-5"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"
    ></path>
  </svg>
</button>

  <Footer />
  <Newletter />
</Layout>

<!-- JS Section -->
<script type="module">
async function fetchProjects() {
  const container = document.getElementById("patent-tables");
  if (!container) return;

  try {
    const res = await fetch(
      "https://script.google.com/macros/s/AKfycbzprqFgJBjsFo9FF1nbY49N_WFieRUnWR4rVzXEA-qKldwi9liB_QntPTMPWmdkiZ4y/exec?tab=year_grouped"
    );

    if (!res.ok) throw new Error("Failed to fetch Sponsored Projects");

    const raw = await res.json();
    if (raw && raw.error) throw new Error(raw.error);
    if (typeof raw !== "object" || Array.isArray(raw)) throw new Error("Invalid data format");

    // year_grouped returns ALL sheets; keep only Sponsored (sheet name contains "spon" or "Sponsored")
    const data = {};
    Object.keys(raw).forEach((year) => {
      const sheets = raw[year];
      if (!Array.isArray(sheets)) return;
      const sponsoredSheets = sheets.filter(
        (s) => s && s.sheet_name && /spon|Sponsored/i.test(s.sheet_name)
      );
      data[year] = sponsoredSheets.flatMap((s) => (s.data ? s.data : []));
    });
    // Drop years with no sponsored rows
    Object.keys(data).forEach((y) => {
      if (!data[y] || data[y].length === 0) delete data[y];
    });

    // Clear loading skeleton
    container.innerHTML = "";


    const summaryData = [
  {
    year: "2023-24",
    projects: 122,
    agencies: 59,
    amount: "₹165,01,01,904",
  },
  {
    year: "2022-23",
    projects: 122,
    agencies: 54,
    amount: "₹104,00,13,945",
  },
  {
    year: "2021-22",
    projects: 145,
    agencies: 55,
    amount: "₹56,11,95,098",
  },
];

// Wrapper for summary table
const summaryWrapper = document.createElement("div");
summaryWrapper.className =
  "overflow-x-auto mb-10 rounded-xl flex flex-col items-center p-6 bg-white";

// Create summary table
const summaryTable = document.createElement("table");
summaryTable.className =
 "text-center text-sm border-collapse w-auto ";

summaryTable.innerHTML = `
  <thead class="bg-green-100 text-green-900 font-semibold text-gray-800">
    <tr>
      <th class="px-4 py-2 border">Financial Year</th>
      <th class="px-4 py-2 border">2023-24</th>
      <th class="px-4 py-2 border">2022-23</th>
      <th class="px-4 py-2 border">2021-22</th>
    </tr>
  </thead>
  <tbody >
    <tr>
      <td class="px-4 py-2 border text-left font-medium">Total No. of Sponsored Projects</td>
      ${summaryData.map((d) => `<td class="px-4 py-2 border">${d.projects}</td>`).join("")}
    </tr>
    <tr>
      <td class="px-4 py-2 border text-left font-medium">Total No. of Funding Agencies</td>
      ${summaryData.map((d) => `<td class="px-4 py-2 border">${d.agencies}</td>`).join("")}
    </tr>
    <tr>
      <td class="px-4 py-2 border text-left font-medium">Total Amount Received in Rupees</td>
      ${summaryData.map((d) => `<td class="px-4 py-2 border font-semibold text-green-700">${d.amount}</td>`).join("")}
    </tr>
  </tbody>
`;

summaryWrapper.appendChild(summaryTable);
container.appendChild(summaryWrapper);



    // Create Year Tabs Container
    const yearTabs = document.createElement("div");
    yearTabs.id = "year-tabs";
    yearTabs.className =
      "flex flex-wrap justify-center gap-3 mb-10 sticky top-16 bg-white py-3 shadow-sm z-30";
    container.appendChild(yearTabs);

    // Get all academic years sorted descending (latest first)
    const years = Object.keys(data).sort((a, b) => b.localeCompare(a));
    if (years.length === 0) {
      container.innerHTML += `<section class="mb-16"><p class="text-center text-gray-600">No sponsored projects data found. Ensure sheet names contain "spon" or "Sponsored" (e.g. 2023-24 Sponsored).</p></section>`;
    }

    years.forEach((year) => {
      const projects = data[year];
      if (!projects || !projects.length) return;

      // Create section for each academic year
      const section = document.createElement("section");
      section.className = "mb-16";
      section.id = `year-${year}`;

      const header = document.createElement("h2");
      header.className =
        "text-2xl font-semibold text-green-700 mb-4 text-center";
      header.textContent = `Sponsored Projects in Sustainability ${year}`;
      section.appendChild(header);

      // Table wrapper
      const tableWrapper = document.createElement("div");
      tableWrapper.className = "overflow-x-auto rounded-xl shadow-md";

      // Create table
      const table = document.createElement("table");
      table.className =
        "min-w-full border border-gray-300 bg-white text-sm text-left";

      // Table header
      table.innerHTML = `
        <thead class="bg-green-100 text-green-900 font-medium">
          <tr>
            <th class="px-4 py-2 border-b">No</th>
            <th class="px-4 py-2 border-b">Project Number</th>
            <th class="px-4 py-2 border-b">Department</th>
            <th class="px-4 py-2 border-b">PIName</th>
            <th class="px-4 py-2 border-b">Agency</th>
            <th class="px-4 py-2 border-b">Project Title</th>
            <th class="px-4 py-2 border-b"> Amount </th>
            <th class="px-4 py-2 border-b">Keywords</th>
          </tr>
        </thead>
        <tbody></tbody>
      `;

      const tbody = table.querySelector("tbody");

      // Populate table rows
      projects.forEach((p, index) => {
        const row = document.createElement("tr");
        row.className = "hover:bg-green-50";
        row.innerHTML = `
          <td class="px-4 py-2 border-b">${index + 1}</td>
          <td class="px-4 py-2 border-b">${p["Project No"] || "-"}</td>
          <td class="px-4 py-2 border-b">${p["Department"]?.trim() || "-"}</td>
          <td class="px-4 py-2 border-b">${p["PIName"]?.trim() || "-"}</td>
          <td class="px-4 py-2 border-b">${p["Agency"] || "-"}</td>
          <td class="px-4 py-2 border-b">${p["ProjectTitle"] || "-"}</td>
          <td class="px-4 py-2 border-b">${p["Amount"] || "-"}</td>
          <td class="px-4 py-2 border-b">${p["Keywords"] || "-"}</td>
        `;
        tbody.appendChild(row);
      });

      tableWrapper.appendChild(table);
      section.appendChild(tableWrapper);
      container.appendChild(section);

      // Add Year Tab Button
      const btn = document.createElement("button");
      btn.textContent = year;
      btn.className =
        "px-4 py-2 text-green-700 hover:bg-green-100 border border-green-600 rounded-md font-medium transition";
      btn.addEventListener("click", () => {
        document
          .getElementById(`year-${year}`)
          .scrollIntoView({ behavior: "smooth" });
      });
      yearTabs.appendChild(btn);
    });
  } catch (err) {
    container.innerHTML = `
      <section class="mb-16">
        <h2 class="text-red-600 text-center">Error loading Sponsored Projects.</h2>
      </section>`;
    console.error("Error fetching projects:", err);
  }
}

// Fetch projects on page load
fetchProjects();

// Scroll-to-Top Button logic
const scrollBtn = document.getElementById("scrollToTop");
if (scrollBtn) {
  window.addEventListener("scroll", () => {
    if (window.scrollY > 200) {
      scrollBtn.classList.remove("opacity-0", "pointer-events-none");
    } else {
      scrollBtn.classList.add("opacity-0", "pointer-events-none");
    }
  });

  scrollBtn.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
}
</script>
