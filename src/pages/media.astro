---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import andrew from "../../public/outreach_images/hero_section.svg";
import MediaData from "../Data/media.json"
import Newletter from "@/components/Newletter.astro";
---

<Layout title="School of Sustainability">
   <main class="overflow-x-hidden" >
    <!-- Hero Section -->
    <section class="relative">
      <div class="relative w-full">
        <!-- Responsive Image Container -->
        <div
          class="relative w-full h-[50vh] sm:h-[60vh] md:h-[70vh] lg:h-[80vh] xl:h-[85vh]"
        >
          <img
            src={andrew.src}
            alt="Hero Image showcasing outreach activities"
            class="w-full h-full sm:h-full lg:h-full object-cover"
            loading="eager"
          />
        </div>

        <!-- Text Overlay - Positioned at Bottom Left -->
        <div
          class="absolute bottom-4 left-4 sm:bottom-6 sm:left-6 md:bottom-8 md:left-8 lg:bottom-10 lg:left-10 z-10"
        >
        </div>
      </div>
    </section>
