---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import Newletter from "../components/Newletter.astro";
import aboutcover from "../assets/About_images/banner5.png";
---

<Layout title="About Us">
  <!-- Banner (same as About page) -->
  <section class="relative overflow-hidden">
    <div class="relative w-full h-[60vh] sm:h-[50vh] md:h-[60vh] lg:h-[88vh] overflow-hidden">
      <img
        src={aboutcover.src}
        alt="Patents Filed at School of Sustainability, IIT Madras"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        decoding="async"
        width="1920"
        height="1080"
      />
      <div class="absolute inset-0 bg-black/30"></div>
    </div>
  </section>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div id="patent-tables">
    <!-- Skeleton row -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold text-green-700 mb-4 text-center">
        Loading Patents...
      </h2>
    </section>
  </div>
</main>


<script type="module">
async function fetchPatents() {
  const container = document.getElementById("patent-tables");
  try {
    const res = await fetch(
      "https://script.google.com/macros/s/AKfycbzprqFgJBjsFo9FF1nbY49N_WFieRUnWR4rVzXEA-qKldwi9liB_QntPTMPWmdkiZ4y/exec?tab=year_grouped"
    );
    if (!res.ok) throw new Error("Failed to fetch patents");

    const raw = await res.json();
    if (raw && raw.error) throw new Error(raw.error);

    // year_grouped returns ALL sheets; include patent-related sheets (name contains "patent", "pate", "filed", "published", or "Patent Details"), then filter by Status
    let allRows = [];
    Object.keys(raw).forEach((year) => {
      const sheets = raw[year];
      if (!Array.isArray(sheets)) return;
      const patentSheets = sheets.filter(
        (s) =>
          s &&
          s.sheet_name &&
          /patent|pate|filed|published|Patent Details/i.test(s.sheet_name)
      );
      patentSheets.forEach((s) => {
        if (s.data && Array.isArray(s.data)) allRows = allRows.concat(s.data);
      });
    });
    const Published = allRows.filter(
      (item) =>
        item["Status of Patent (Published / Granted)"] === "Published" ||
        (item["Status of Patent (Published / Granted)"] && String(item["Status of Patent (Published / Granted)"]).trim().toLowerCase().startsWith("pub"))
    );

    container.innerHTML = "";

    if (Published.length === 0) {
      container.innerHTML = `<section class="mb-16"><p class="text-center text-gray-600">No patents filed data found. Ensure sheet names contain "filed" or "published" and rows have Status "Published".</p></section>`;
      return;
    }

 const summaryData = [
  {
    year: "2023",
    published :97,
  },
  {
    year: "2022",
      published :70,
  },
  {
    year: "2021",
     published :51,
  },
];

    // Wrapper for summary table
const summaryWrapper = document.createElement("div");
summaryWrapper.className =
  "overflow-x-auto mb-10 rounded-xl flex flex-col items-center p-6 bg-white";

// Create table
const summaryTable = document.createElement("table");
summaryTable.className =
  "text-center text-sm border-collapse w-auto ";


summaryTable.innerHTML = `
  <thead class="bg-green-100 text-green-900 font-semibold text-gray-800">
    <tr>
      <th class="px-4 py-2 border">Calendar Year</th>
      <th class="px-4 py-2 border">2023</th>
      <th class="px-4 py-2 border">2022</th>
      <th class="px-4 py-2 border">2021</th>
    </tr>
  </thead>
  <tbody >
    <tr>
      <td class="px-4 py-2 border text-left font-medium">No of Patents published (related to sustainability)</td>
      ${summaryData.map((d) => `<td class="px-4 py-2 border">${d.published}</td>`).join("")}
    </tr>
    
  </tbody>
`;

summaryWrapper.appendChild(summaryTable);
container.appendChild(summaryWrapper);


    // year Tabs to move 
  const yearTabs = document.createElement("div");
    yearTabs.id = "year-tabs";
    yearTabs.className =
      "flex flex-wrap justify-center gap-3 mb-10 sticky top-16 bg-white py-3 shadow-sm z-30";
    container.appendChild(yearTabs);

const groupedByYear = {};
    Published.forEach((p) => {
      const publishedDate = p["Patent Published Date / Granted Date (DD/MM/YYYY)"];
      let yr = "Unknown";


  if (publishedDate) {
    const d = new Date(publishedDate);
    if (!isNaN(d)) yr = d.getFullYear().toString();
  }
     if (!groupedByYear[yr]) groupedByYear[yr] = [];
  groupedByYear[yr].push(p);
});
     const sortedYears = Object.keys(groupedByYear)
      .filter((y) => y !== "Unknown")
      .sort((a, b) => b - a);

      sortedYears.forEach((year) => {

    const section = document.createElement("section");
      section.className = "mb-16";
      section.id = `year-${year}`;

      const header = document.createElement("h2");
      header.className = "text-2xl font-semibold text-green-700 mb-4 text-center";
      header.textContent = `Patents Filed ${year} `;
      section.appendChild(header);

      const tableWrapper = document.createElement("div");
      tableWrapper.className = "overflow-x-auto rounded-xl shadow-md";

      const table = document.createElement("table");
      table.className = "min-w-full border border-gray-300 bg-white text-sm text-left";

      table.innerHTML = `
        <thead class="bg-green-100 text-green-900 font-medium">
          <tr>
            <th class="px-4 py-2 border-b">No</th>
            <th class="px-4 py-2 border-b">Patent Application No</th>
            <th class="px-4 py-2 border-b">Inventor/s Name</th>
            <th class="px-4 py-2 border-b">Title of the Patent</th>
            <th class="px-4 py-2 border-b">Applicant/s Name</th>
            <th class="px-4 py-2 border-b">Patent Filed Date</th>
            <th class="px-4 py-2 border-b">Patent Published Date</th>
            <th class="px-4 py-2 border-b">Patent Publication Number /</th>
            <th class="px-4 py-2 border-b">Assignee/s Name</th>
            <th class="px-4 py-2 border-b">Country</th>
            <th class="px-4 py-2 border-b">Sustainability</th>
          </tr>
        </thead>
        <tbody></tbody>
      `;

      const tbody = table.querySelector("tbody");

      groupedByYear[year].forEach((p,index) => {
          const filedDate = new Date(p["Patent Filed Date (DD/MM/YYYY) "]);
    const formattedFiled = !isNaN(filedDate)
      ? filedDate.toLocaleDateString("en-GB")
      : "-";
        const publishedDate = new Date(p["Patent Published Date / Granted Date (DD/MM/YYYY)"]);
    const formattedPublished = !isNaN(publishedDate)
      ? publishedDate.toLocaleDateString("en-GB")
      : "-";
         const row = document.createElement("tr");
        row.className = "hover:bg-green-50";
        row.innerHTML = `
          <td class="px-4 py-2 border-b">${index+1}</td>
          <td class="px-4 py-2 border-b">${p["Patent Application No."] || "-"}</td>
          <td class="px-4 py-2 border-b">${p["Inventor/s Name"]|| "-"}</td>
          <td class="px-4 py-2 border-b">${p["Title of the Patent"] || "-"}</td>
          <td class="px-4 py-2 border-b">${p["Applicant/s Name"] || "-"}</td>
          <td class="px-4 py-2 border-b">${formattedFiled}</td>
          <td class="px-4 py-2 border-b">${formattedPublished}</td>
          <td class="px-4 py-2 border-b">${p["Patent Publication Number / Patent Granted Number"]|| "-"}</td>
          <td class="px-4 py-2 border-b">${p["Assignee/s Name (Institute Affiliation/s at time of Appication)"]|| "-"}</td>
          <td class="px-4 py-2 border-b">${p["Country"]|| "-"}</td>
          <td class="px-4 py-2 border-b">${p["Sustainability"]|| "-"}</td>
        `;
        tbody.appendChild(row);
      });

      tableWrapper.appendChild(table);
      section.appendChild(tableWrapper);
      container.appendChild(section);

       const btn = document.createElement("button");
      btn.textContent = year;
      btn.className =
        "px-4 py-2 text-green-700 hover:bg-green-100 border border-green-600 rounded-md font-medium transition";
      btn.addEventListener("click", () => {
        document
          .getElementById(`year-${year}`)
          .scrollIntoView({ behavior: "smooth" });
      });
      yearTabs.appendChild(btn);
    })
  } catch(err) {
    container.innerHTML = `<section class="mb-16"><h2 class="text-red-600 text-center">Error loading patents.</h2></section>`;
    console.error(err);
  }
}

fetchPatents();

const scrollBtn = document.getElementById("scrollToTop");
  if (scrollBtn) {
    window.addEventListener("scroll", () => {
      if (window.scrollY > 200) {
        scrollBtn.classList.remove("opacity-0", "pointer-events-none");
      } else {
        scrollBtn.classList.add("opacity-0", "pointer-events-none");
      }
    });

    scrollBtn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }
</script>
<Newletter />
<button
  id="scrollToTop"
  class="fixed bottom-6 right-6 z-50 bg-white border-2 border-green-600 text-green-600 p-3 rounded-full shadow-md transition-all duration-300 opacity-0 pointer-events-none"
  aria-label="Scroll to top"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="w-5 h-5"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"
    ></path>
  </svg>
</button>
<Footer />
</Layout>
