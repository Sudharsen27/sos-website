        >
          Ethics Courses
        </h3>

        {/* Ethics Cards Grid - same white card style for all; no background change */}
        <div
          class="grid grid-cols-1 md:grid-cols-2 gap-8 sm:gap-10 lg:gap-12"
        >
          {
            ethicsCourses.map((course) => (
              <article class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col max-w-md mx-auto w-full">
                {/* Image Container */}
                <div class="h-64 bg-gray-100 overflow-hidden">
