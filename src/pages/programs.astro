      class="w-full h-[52vh] sm:h-[67vh] md:h-[77vh] lg:h-[87vh] object-cover object-center mt-2"
      loading="eager"
      decoding="async"
      width="1920"
      height="1080"
    />

    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-black/40"></div>
  </div>
</section>



    <!-- Tab Navigation -->
    <div
  class="
    flex justify-center items-center gap-3 py-3 whitespace-nowrap
    border-b border-gray-300
    [@media(hover:none)]:whitespace-normal
    [@media(hover:none)]:flex-wrap
  "
>


      <a
        href="#certificate"
        class="text-green-700 hover:text-green-900 active:text-green-950 font-medium text-base sm:text-lg md:text-xl lg:text-xl transition-all duration-300 px-4 py-2.5 rounded-lg hover:bg-green-100 focus:outline-none focus-visible:ring-2 focus-visible:ring-green-500 focus-visible:ring-offset-2 "
