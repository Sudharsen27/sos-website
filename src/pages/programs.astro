                  {/* Button Container */}
                  <div class="mt-auto">
                    <a
                      href={course.link || course.file}
                      target={course.link ? "_self" : "_blank"}
                      rel="noopener noreferrer"
                      class="border-2 border-[#3DAA6F] text-black hover:bg-[#3DAA6F] hover:text-white font-semibold rounded-lg text-lg px-6 py-2 transition-all duration-300 ease-in-out hover:-translate-y-0.5 hover:shadow-lg flex justify-center"
                    >
                      Read More
                    </a>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <!-- Courses and Assessments on Sustainability Section -->
   <section
  id="sustainability"
  class="mb-16 sm:mb-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-r from-[#064924] to-[#519335] py-16 scroll-mt-24 rounded-2xl mx-4 sm:mx-6 lg:mx-8"
  aria-labelledby="sustainability"
>
  <div class="max-w-6xl mx-auto">

    <h3
      class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-semibold text-white border-l-4 border-[#519335] pl-3 sm:pl-4 mb-8 sm:mb-12"
    >
      Courses and Assessments on Sustainability
    </h3>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8 lg:gap-10 w-full">
      {sustainabilityCourses.map((course) => (
        <article
          class="bg-gradient-to-r from-[#064924] to-[#519335] rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col border border-white/20"
        >
          <div class="h-64 bg-gray-100 overflow-hidden">
            <img
              src={course.image.src}
              alt={course.title}
              class="h-full w-full object-cover"
              loading="lazy"
              decoding="async"
              width={course.image.width}
              height={course.image.height}
            />
          </div>

          <div class="p-6 sm:p-8 flex flex-col flex-grow">
            <h4 class="text-xl font-bold text-white mb-4 leading-tight">
              {course.title}
            </h4>

            {course.description && (
              <p class="text-sm sm:text-base text-white/90 leading-relaxed mb-8 flex-grow">
                {course.description}
              </p>
            )}

            <div class="mt-auto">
              <a
                href={course.link || course.file}
                target={course.link ? "_self" : "_blank"}
                rel="noopener noreferrer"
                class="border-2 border-white text-white hover:bg-white hover:text-[#064924] font-semibold rounded-lg text-lg px-6 py-2 transition-all duration-300 ease-in-out hover:-translate-y-0.5 hover:shadow-lg flex justify-center"
              >
               Read More
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

    </div>
  </main>
</Layout>

<Newsletter />
<button
  id="scrollToTop"
  class="fixed bottom-6 right-6 z-50 bg-white border-2 border-green-600 text-green-600 p-3 rounded-full shadow-md transition-all duration-300 opacity-0 pointer-events-none"
  aria-label="Scroll to top"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="w-5 h-5"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"
    ></path>
  </svg>
</button>
<script>
  const scrollBtn = document.getElementById("scrollToTop");
  if (scrollBtn) {
    window.addEventListener("scroll", () => {
      if (window.scrollY > 200) {
        scrollBtn.classList.remove("opacity-0", "pointer-events-none");
      } else {
        scrollBtn.classList.add("opacity-0", "pointer-events-none");
      }
    });

    scrollBtn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }
</script>
<Footer />

<style>
  html {
    scroll-behavior: smooth;
  }

  /* Enhanced focus styles for better accessibility */
  .focus-visible {
    outline: 2px solid #10b981;
    outline-offset: 2px;
  }

  /* Custom scrollbar for better UX */
  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-track {
    background: #f1f1f1;
  }

  ::-webkit-scrollbar-thumb {
    background: #10b981;
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: #059669;
  }
  .no-scrollbar::-webkit-scrollbar {
  display: none;
}
.no-scrollbar {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

</style>