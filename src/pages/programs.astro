                  <h4 class="text-xl sm:text-2xl font-bold text-gray-900 mb-4 leading-tight">
                    {course.title}
                  </h4>

                  {course.description && (
                    <p class="text-sm sm:text-base text-gray-700 leading-relaxed mb-8 flex-grow">
                      {course.description}
                    </p>
