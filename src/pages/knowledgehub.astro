    <section
    id="newsletter"
    class="py-16 scroll-mt-19 bg-linear-to-r from-[#064924] to-[#519335] rounded-xl"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <h2
        class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-semibold text-white border-l-4 border-green-600 pl-3 sm:pl-4 mb-4 sm:mb-6"
      >
        Newsletter
      </h2>
  
      <div
        id="newsletterGrid"
        class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8"
      >
        {
          Newsletter
            .sort((a, b) => {
              const getEndDate = (str: string) => {
                const months: { [key: string]: number } = {
                  January: 0, February: 1, March: 2, April: 3, May: 4, June: 5,
                  July: 6, August: 7, September: 8, October: 9, November: 10, December: 11
                };
                const parts = str.split(" - ");
                const endPart = parts[1] ?? parts[0];
                const [monthStr, yearStr] = endPart.trim().split(" ");
                return new Date(parseInt(yearStr), months[monthStr] ?? 0);
              };
  
              return getEndDate(b.year).getTime() - getEndDate(a.year).getTime();
            })
            .map((newsletter, index) => (
              <div class="relative overflow-hidden rounded-2xl bg-white/40 backdrop-blur-sm border border-white/20 shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 group">
  
                <div class="relative overflow-hidden rounded-t-2xl bg-linear-to-r from-[#064924] to-[#519335] rounded-xl w-full">
                  <a
                    href={newsletter.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="block"
                  >
                    <img
                      src={newsletter.image}
                      alt={newsletter.alt}
                      class="w-full h-80 object-contain p-4 transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
  
                    <div class="absolute inset-0 bg-gradient-to-t from-black/10 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                  </a>
                </div>
  
                <div
                  class="absolute bottom-0 left-0 right-0 text-white text-lg font-semibold bg-[#3DAA6F]/80 py-2 text-center translate-y-full group-hover:translate-y-0 transition-transform duration-500"
                >
                  {newsletter.year}
                </div>
  
                <div class="absolute bottom-0 left-0 right-0 h-1 border-2 border-[#3DAA6F] hover:bg-[#3DAA6F] rounded-md" />
              </div>
            ))
        }
      </div>
  
    </div>
  </section>


  </main>

  <Newletter />
  <button
  id="scrollToTop"
  class="fixed bottom-6 right-6 z-50 bg-white border-2 border-green-600 text-green-600 p-3 rounded-full shadow-md transition-all duration-300 opacity-0 pointer-events-none"
  aria-label="Scroll to top"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="w-5 h-5"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"
    ></path>
  </svg>
</button>
<script>
  const scrollBtn = document.getElementById("scrollToTop");
  if (scrollBtn) {
    window.addEventListener("scroll", () => {
      if (window.scrollY > 200) {
        scrollBtn.classList.remove("opacity-0", "pointer-events-none");
      } else {
        scrollBtn.classList.add("opacity-0", "pointer-events-none");
      }
    });

    scrollBtn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }
</script>
  <Footer />

<script>
document.addEventListener('DOMContentLoaded', function() {
  const publicationCards = document.querySelectorAll('.publication-card');
  
  publicationCards.forEach(card => {
    const tooltip = card.querySelector('.publication-tooltip');
    const closeBtn = tooltip?.querySelector('.tooltip-close');

    if (tooltip) {
      closeBtn?.addEventListener('click', function(e) {
        e.stopPropagation();
        tooltip.classList.add('force-hidden');
      });

      card.addEventListener('mouseleave', function() {
        tooltip.classList.remove('force-hidden');
      });
    }
  });
});
</script>


  <style>
    
/* ===============================
   Card
================================ */
.publication-card {
  position: relative;
  z-index: 1;
  transition: filter 0.3s ease;
}

/* ===============================
   Tooltip (overlay ON card)
================================ */
.publication-tooltip {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;

  opacity: 0;
  visibility: hidden;
  pointer-events: none;

  transform: scale(0.95);
  transition: opacity 0.3s ease, transform 0.3s ease;
  z-index: 50;
}

.publication-card:hover .publication-tooltip {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: scale(1);
}

/* Used by your JS */
.publication-tooltip.force-hidden {
  opacity: 0 !important;
  visibility: hidden !important;
  pointer-events: none !important;
  transform: scale(0.95) !important;
}

/* ===============================
   Blur effect
================================ */
#publicationGrid:hover .publication-card {
  filter: blur(4px) brightness(0.8);
}

#publicationGrid:hover .publication-card:hover {
  filter: none;
  z-index: 20;
}

/* Prevent clipping */
#publicationGrid {
  overflow: visible;
}

/* ===============================
   Animation
================================ */
@keyframes fade-in-up {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in-up {
  animation: fade-in-up 0.6s ease-out both;
}

  </style>
</Layout>