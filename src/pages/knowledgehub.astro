        >
          Reports
        </a>
        <span class="text-gray-300 hidden sm:inline">|</span>
        <a
          href="#whitepaper"
          class="text-green-700 hover:text-green-900 active:text-green-950 font-medium text-base sm:text-lg md:text-xl lg:text-xl transition-all duration-300 px-4 py-2.5 rounded-lg hover:bg-green-100 focus:outline-none focus-visible:ring-2 focus-visible:ring-green-500 focus-visible:ring-offset-2"
        >
          White Papers
        </a>
        <span class="text-gray-300 hidden sm:inline">|</span>
        <a
          href="#newsletter"
          class="text-green-700 hover:text-green-900 active:text-green-950 font-medium text-base sm:text-lg md:text-xl lg:text-xl transition-all duration-300 px-4 py-2.5 rounded-lg hover:bg-green-100 focus:outline-none focus-visible:ring-2 focus-visible:ring-green-500 focus-visible:ring-offset-2"
        >
          Newsletters
        </a>
      </div>
    </div>
  </nav>
 </section>

  <main class="max-w-7xl mx-auto px-8">

    <!-- Publications Section -->

<section id="publications" class="py-16 scroll-mt-24">
  <div class="max-w-7xl mx-auto">

    <h2
      class="text-xl sm:text-2xl md:text-3xl lg:text-4xl
             font-semibold text-gray-900
             border-l-4 border-green-600
             pl-4 mb-6"
    >
      Publications
    </h2>

    <div class="relative">

      <!-- <div
        class="absolute inset-0 bg-cover bg-center bg-no-repeat rounded-3xl"
        style={`background-image: url(${peoplehome.src})`}
      ></div> -->

      <div
        id="publicationGrid"
        class="relative grid md:grid-cols-3 lg:grid-cols-4 gap-8 p-6 overflow-visible"
      >
        {publications.map((pub, index) => (
          <div
            class="publication-card animate-fade-in-up"
            style={`animation-delay:${index * 100}ms`}
          >
            <!-- CARD -->
            <div
              class="overflow-hidden rounded-2xl bg-white/40 backdrop-blur-sm
                     border border-white/20 shadow-lg transition-all duration-300"
