              <div class="bg-gradient-to-br from-gray-50 to-gray-100">
                <img
                  src={pub.image}
                  alt={pub.alt}
                  class="w-full h-80 object-contain p-4"
                  loading="lazy"
                />
              </div>
              <div class="h-1 bg-[#3DAA6F]"></div>
            </div>

            <!-- TOOLTIP -->
            <div class="publication-tooltip">
              <div class="bg-white rounded-xl shadow-2xl p-6 w-[90%] max-w-sm relative">
                <button
                  class="tooltip-close absolute top-3 right-3
                         w-8 h-8 bg-gray-800 text-white rounded-full"
                >
                  ×
                </button>

                <h3 class="font-semibold text-lg mb-3">{pub.alt}</h3>

                <p class="text-gray-700 leading-relaxed mb-4">
                  {pub.details}
                </p>

                {pub.link && (
                  <a
                    href={pub.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex px-4 py-2
                           bg-green-600 text-white rounded-lg
                           hover:bg-green-700 transition"
                  >
                    View Publication 
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>


    
<section
id="reports"
