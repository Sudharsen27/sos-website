    <div class="absolute inset-0 bg-black/40 flex items-center justify-center px-4 sm:px-6 lg:px-12"></div>
  </div>
</section>




  
  <!-- Navigation Links -->
 <section>
  <!-- Navigation Links -->
  <nav
    class="sticky top-0 z-10 bg-white shadow-sm border-b border-gray-200"
    aria-label="Health and Safety navigation"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
