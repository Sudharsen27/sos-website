---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import OutReachEventData from "../Data/outreach_events.json";

// Import assets

import stem from "../assets/stem1.svg";
import school from "../assets/school.svg";
import andrew from "../../public/outreach_images/Outreach Page.png";
import Newletter from "../components/Newletter.astro";
import MediaData from "../Data/media.json"

import VentureLogo from "../assets/entrepreneurship/VentureLogo.jpg";
import CompetitionLogo from "../assets/entrepreneurship/CompetitionLogo.png";



// const SHEETS_API_URL = "https://script.google.com/macros/s/AKfycbwTyk22Yv_8pAC0IEuJIUQKIGkKeeVqBYvghpPBoUPOw9H1MC8zQAyKqeFJFnjUxucLmA/exec?ts=" + Date.now();

let upcomingEvents: any[] = [];
let pastEvents: any[] = [];
let activeTab: 'upcoming' | 'past' = 'upcoming';
const today = new Date();
upcomingEvents=OutReachEventData.filter((e: any) => new Date(e.Date) >= today)
pastEvents = OutReachEventData.filter((e: any) => new Date(e.Date) < today);


