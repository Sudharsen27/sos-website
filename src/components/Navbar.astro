          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M1 1h15M1 7h15M1 13h15"></path>
      </svg>
    </button>

    <!-- Navbar Links -->
    <div
  id="navbar-default"
  class="hidden w-full xl:block xl:w-auto bg-white xl:bg-transparent"
>

    <ul
