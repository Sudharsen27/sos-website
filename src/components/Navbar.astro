---
import imageUrl from "../assets/logo_sos-removebg-preview.webp";
---

<style>
  .backdrop-blur-glass {
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }
  .transition-navbar {
    transition: all 0.3s ease-in-out;
  }
  /* Ensure dropdown appears above other content */
  .dropdown-menu {
    z-index: 9999 !important;
  }

  /* Fix text colors in dropdown */
  .dropdown-menu a {
    color: #374151 !important; /* gray-700 */
  }

  .dropdown-menu a:hover {
    background-color: #f3f4f6 !important; /* gray-100 */
  }

  /* Ensure dropdown button arrow rotates */
  .dropdown-arrow {
    transition: transform 0.2s ease;
  }

  .dropdown-open .dropdown-arrow {
    transform: rotate(180deg);
  }

  /* Active nav link - current page */
  .nav-link-active {
    color: #059669 !important; /* green-600 */
    font-weight: 700;
    border-bottom: 2px solid #059669;
    padding-bottom: 2px;
  }

  /* Smooth scroll behavior */
  html {
    scroll-behavior: smooth;
  }
</style>

<nav
  id="navbar"
class="fixed top-0 left-0 right-0 z-50 w-full backdrop-blur-glass text-black transition-navbar"
>
  <div
    class="max-w-screen-3xl flex flex-wrap items-center justify-between mx-auto p-2 lg:p-2 lg:px-20"
  >
    <!-- Logo with reduced height -->
    <a href="/" class="flex items-center space-x-3">
<div class="inline-flex items-center justify-center bg-white rounded-full ">
  <img
    src={imageUrl.src}
    alt="Logo"
    class="h-[60px] lg:h-[60px] w-auto object-contain"
  />
</div>    </a>

    <!-- Mobile Toggle Button -->
