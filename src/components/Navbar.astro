<script>
  document.addEventListener("DOMContentLoaded", () => {
    const navbar = document.getElementById("navbar");
    const links = document.querySelectorAll(".navbar-link");
    const mobileBtn = document.getElementById("mobile-menu-button");
    const menu = document.getElementById("navbar-default");

    // Set active nav link based on current page
    const path = window.location.pathname.replace(/\/$/, "") || "/";
    const activeNav =
      path === "/about" || path === "/people"
        ? "about"
        : path === "/research"
          ? "research"
          : path === "/programs"
            ? "programs"
            : path === "/outreach" || path === "/media"
              ? "outreach"
              : path === "/knowledgehub"
                ? "knowledgehub"
                : path === "/organisation" ||
                    path === "/health" ||
                    path === "/policies" ||
                    path.startsWith("/organisation/")
                  ? "organisation"
                  : null;
    document.querySelectorAll("[data-nav]").forEach((a) => {
      a.classList.toggle("nav-link-active", a.getAttribute("data-nav") === activeNav);
    });

    // About dropdown elements
    const aboutBtn = document.getElementById("about-dropdown-button");
    const aboutDropdown = document.getElementById("about-dropdown");

    // Research dropdown elements
    const researchBtn = document.getElementById("research-dropdown-button");
    const researchDropdown = document.getElementById("research-dropdown");

    // Programs dropdown elements
    const programsBtn = document.getElementById("programs-dropdown-button");
    const programsDropdown = document.getElementById("programs-dropdown");

    // Outreach dropdown elements
    const outreachBtn = document.getElementById("outreach-dropdown-button");
    const outreachDropdown = document.getElementById("outreach-dropdown");

    // Knowledge Hub dropdown elements
    const knowledgehubBtn = document.getElementById(
      "knowledgehub-dropdown-button"
    );
    const knowledgehubDropdown = document.getElementById(
      "knowledgehub-dropdown"
    );

    // Sustainability dropdown elements
    const sustainabilityBtn = document.getElementById(
      "sustainability-dropdown-button"
    );
    const sustainabilityDropdown = document.getElementById(
      "sustainability-dropdown"
    );

    // Array of all dropdown elements for easy management
    const dropdowns = [
      { btn: aboutBtn, dropdown: aboutDropdown, name: "about" },
      { btn: researchBtn, dropdown: researchDropdown, name: "research" },
      { btn: programsBtn, dropdown: programsDropdown, name: "programs" },
      { btn: outreachBtn, dropdown: outreachDropdown, name: "outreach" },
      {
        btn: knowledgehubBtn,
        dropdown: knowledgehubDropdown,
        name: "knowledgehub",
      },
      {
        btn: sustainabilityBtn,
        dropdown: sustainabilityDropdown,
        name: "sustainability",
      },
    ];

    // Mobile toggle
    mobileBtn?.addEventListener("click", () => {
      menu?.classList.toggle("hidden");
    });

    // Function to close all dropdowns except the one specified
    /**
     * @param {string | null | undefined} except
     */
    function closeAllDropdowns(except: string | null | undefined = null) {
      dropdowns.forEach(({ btn, dropdown, name }) => {
        if (name !== except) {
          dropdown?.classList.add("hidden");
          btn?.classList.remove("dropdown-open");
        }
      });
    }

    // Add click event listeners for all dropdown buttons
    dropdowns.forEach(({ btn, dropdown, name }) => {
      btn?.addEventListener("click", (e) => {
        e.stopPropagation();
        const isOpen = !dropdown?.classList.contains("hidden");

        if (isOpen) {
          // Close this dropdown
          dropdown?.classList.add("hidden");
          btn?.classList.remove("dropdown-open");
        } else {
          // Close all other dropdowns and open this one
          closeAllDropdowns(name);
          dropdown?.classList.remove("hidden");
          btn?.classList.add("dropdown-open");
        }
      });
    });

    // Handle section scrolling for dropdown links
    document.querySelectorAll('.dropdown-link').forEach(link => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        if (href && href.includes('#')) {
          const [path, hash] = href.split('#');
          
          // Get current page path (handle both /about and /research)
          const currentPath = window.location.pathname;
          const targetPath = path || currentPath;
          
          // If we're on the same page, prevent default and scroll
          if (targetPath === currentPath || 
              (targetPath === '/about' && currentPath === '/about') ||
              (targetPath === '/research' && currentPath === '/research') ||
              (targetPath === '/programs' && currentPath === '/programs') ||
              (targetPath === '/outreach' && currentPath === '/outreach') ||
              (targetPath === '/knowledgehub' && currentPath === '/knowledgehub')) {
            e.preventDefault();
            const targetSection = document.getElementById(hash);
            
            if (targetSection) {
              // Close all dropdowns
              closeAllDropdowns();
              
              // Calculate navbar height for offset
              const navbarHeight = navbar?.offsetHeight || 80;
              const targetPosition = targetSection.offsetTop - navbarHeight - 20;
              
              // Smooth scroll to section
              window.scrollTo({
                top: targetPosition,
                behavior: 'smooth'
              });
            }
          }
          // If we're on a different page, let the default navigation happen
          // The browser will automatically scroll to the hash after page load
        }
      });
    });

    // Close all dropdowns when clicking outside
    document.addEventListener("click", (e) => {
      const target = e.target as Node;
      let clickedInside = false;

      dropdowns.forEach(({ btn, dropdown }) => {
        if (btn?.contains(target) || dropdown?.contains(target)) {
          clickedInside = true;
        }
      });

      if (!clickedInside) {
        closeAllDropdowns();
      }
    });

  function updateNavbar() {
  const navbar = document.getElementById("navbar");
  const mobileBtn = document.getElementById("mobile-menu-button");
  const links = document.querySelectorAll(".navbar-link");

  if (!navbar) return;

  const atTop = window.scrollY <= 50;

  if (atTop) {
    // Transparent + neutral text
    navbar.classList.add("backdrop-blur-glass");
    navbar.classList.remove("bg-white", "shadow-md", "text-black");

    // Remove any color overrides and force neutral
    navbar.classList.add("text-neutral-400");

    mobileBtn?.classList.remove("text-black", "text-gray-500");
    mobileBtn?.classList.add("text-neutral-400");

    links.forEach((link) => {
      link.classList.remove("text-black", "text-white");
      link.classList.add("text-neutral-400");
    });
  } else {
    // Solid white + black text
    navbar.classList.add("bg-white", "shadow-md", "text-black");
    navbar.classList.remove("backdrop-blur-glass", "text-neutral-400");

    mobileBtn?.classList.remove("text-neutral-400");
    mobileBtn?.classList.add("text-black");

    links.forEach((link) => {
      link.classList.remove("text-neutral-400");
      link.classList.add("text-black");
    });
  }
}

updateNavbar();
window.addEventListener("scroll", () => requestAnimationFrame(updateNavbar));

});
</script>







